@article{dasilvaSynthesisCharacterizationAntichagasic2021,
 abstract = {Chagas disease is a neglected disease, being one of the leading causes of death from infectious diseases. In view of the severity of this pathology, this work describes the synthesis of new thiosemicarbazones derived from chalcones and dibenzalacetones as potential drugs for the treatment of this disease. The structures of all compounds were elucidated by infrared (IR) and nuclear magnetic resonance (1H and 13C NMR) spectroscopies. The chalcone derived thiosemicarbazones 10-14 were tested against the intracellular amastigote form of the protozoan Trypanosoma cruzi and had their cytotoxicity assessed using LLC-MK2 cells. The compound 10 (IC50~=~12.25 \textmu M) presented the best activity when compared with the standard drug benznidazole (IC50~=~5.64 \textmu M).},
 author = {da Silva, Aline Alves and Maia, Pedro Ivo da Silva and Lopes, Carla Duque and de Albuquerque, Sergio and Valle, Marcelo Siqueira},
 doi = {10.1016/j.molstruc.2021.130014},
 file = {/home/lraposo/Zotero/storage/HU2SNM7K/da Silva et al. - 2021 - Synthesis, characterization and antichagasic evaluation of thiosemicarbazones prepared from chalcone.pdf;/home/lraposo/Zotero/storage/SEBGLV3L/S0022286021001459.html},
 issn = {0022-2860},
 journal = {Journal of Molecular Structure},
 keywords = {Chagas disease,Thiosemicarbazones},
 month = {May},
 pages = {130014},
 title = {Synthesis, Characterization and Antichagasic Evaluation of Thiosemicarbazones Prepared from Chalcones and Dibenzalacetones},
 urldate = {2026-03-27},
 volume = {1232},
 year = {2021}
}
