@article{souzaFrequencyUpconversionTwophoton2013,
 abstract = {Two-photon absorption and two-photon excitation fluorescence of salicylaldehyde azine 1 crystals were investigated. It was observed an intense visible fluorescence when this material was excited with a laser tuned at the near infrared region. Varying the laser intensity we characterized this phenomenon as a simultaneous two-photon laser absorption process. Using open aperture Z-scan measurements we characterized this two-photon absorption phenomenon and measured the value of the two-photon absorption cross-section of this molecule to be equal to 87GM. Our results indicate that this is a promising organic material aiming nonlinear photonics applications.},
 author = {Souza, A. B. and Alencar, M. A. R. C. and Cardoso, S. H. and Valle, M. S. and Diniz, R. and Hickmann, J. M.},
 doi = {10.1016/j.optmat.2013.07.020},
 file = {/home/lraposo/Zotero/storage/QZ95AN63/Souza et al. - 2013 - Frequency upconversion and two-photon absorption of salicylaldehyde azine 1.pdf;/home/lraposo/Zotero/storage/8V4G3BW5/S0925346713004023.html},
 issn = {0925-3467},
 journal = {Optical Materials},
 keywords = {Frequency upconversion,Organic crystal,Salicyaldehyde azine,Two-photon absorption},
 month = {October},
 number = {12},
 pages = {2535--2539},
 title = {Frequency Upconversion and Two-Photon Absorption of Salicylaldehyde Azine 1},
 urldate = {2026-03-27},
 volume = {35},
 year = {2013}
}
