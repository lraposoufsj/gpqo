@article{tarrade-mathaEnantiospecificSynthesisProtected2009,
 abstract = {The efficient synthesis of a protected form of (2S,3R,4S,5S,7E)-3-amino-8-phenyl-2,4,5-trihydroxyoct-7-enoic acid (APTO), the $α$-hydroxy $β$-amino acid component of microsclerodermins C and D, 23-membered cyclic peptides isolated from lithistid sponges, is described. The strategy is based on the preparation of the aziridino-$γ$-lactone 46 from L-gulose by a procedure previously developed in our laboratory for simpler substrates. Regioselective opening of the aziridine at C-2 by acetate anion, an intrinsic reactivity pattern of aziridino-$γ$-lactones, followed by a Heck reaction to install the terminal phenyl group, provides lactone 48. This, a lactonized form of APTO, can be considered an activated building block for the synthesis of microsclerodermins C and D or their analogues, as demonstrated by its subsequent reaction with a benzylamine to give the carboxamide 51. This represents the first example of the use of an aziridino-$γ$-lactone for the stereoselective synthesis of an $α$-substituted $β$-amino acid derivative. (o̧pyright Wiley-VCH Verlag GmbH & Co. KGaA, 69451 Weinheim, Germany, 2009)},
 author = {Tarrade-Matha, Aurélie and Valle, Marcelo Siqueira and Tercinier, Pierre and Dauban, Philippe and Dodd, Robert H.},
 copyright = {Copyright o̧pyright 2009 WILEY-VCH Verlag GmbH & Co. KGaA, Weinheim},
 doi = {10.1002/ejoc.200801000},
 file = {/home/lraposo/Zotero/storage/RFL34E7U/Tarrade-Matha et al. - 2009 - Enantiospecific Synthesis of a Protected Equivalent of APTO, the β-Amino Acid Fragment of Microscler.pdf;/home/lraposo/Zotero/storage/47VLBR3X/ejoc.html},
 issn = {1099-0690},
 journal = {European Journal of Organic Chemistry},
 keywords = {Amino acids,Aziridines,Microsclerodermins,Nucleophilic ring-opening,Synthesis design},
 langid = {english},
 number = {5},
 pages = {673--686},
 title = {Enantiospecific Synthesis of a Protected Equivalent of APTO, the $β$-Amino Acid Fragment of Microsclerodermins C and D, by Aziridino-$γ$-lactone Methodology},
 urldate = {2026-03-27},
 volume = {2009},
 year = {2009}
}
