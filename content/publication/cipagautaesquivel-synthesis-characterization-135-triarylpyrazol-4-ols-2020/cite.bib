@article{cipagautaesquivelSynthesisCharacterization135triarylpyrazol4ols2020,
 abstract = {The synthesis of diverse pyrazol-4-ol and isoxazole-4-ol heterocycles involving only 3 reaction steps is reported in this study. However, the synthesis of carboxamide pyrazol-4-ol has failed in the conditions used in the synthesis, acid methanol solution. The carboxamide pyrazol-4-ol decomposes via dehydration, forming the respective pyrazol. Theoretical calculations were used to elucidate the dehydration reaction. We have found a mechanism for acid-catalyzed dehydration that can explain the experimental observations. The calculated free energy profile for acid-catalyzed dehydration of the carboxamide pyrazol-4-ol and phenylpyrazole-4-ol point out that the latter is more stable in relation dehydration, with a dehydration rate 100 times smaller in acid methanol solution.},
 author = {Cipagauta Esquivel, Edna Carolina and Rufino, Virgínia Camila and Trindade Nogueira, Matheus Henrique and Carbonaro Souza, Ana Carolina and Pliego Júnior, Josefredo Rodriguez and Valle, Marcelo Siqueira},
 doi = {10.1016/j.molstruc.2019.127536},
 file = {/home/lraposo/Zotero/storage/GUZUW2PH/Cipagauta Esquivel et al. - 2020 - Synthesis and characterization of 1,3,5-triarylpyrazol-4-ols and 3,5-diarylisoxazol-4-ols from chalc.pdf;/home/lraposo/Zotero/storage/YJSYZP33/S002228601931645X.html},
 issn = {0022-2860},
 journal = {Journal of Molecular Structure},
 keywords = {Dehydration mechanism,DFT,Heterocycles,Pyrazol,Theoretical calculations},
 month = {March},
 pages = {127536},
 title = {Synthesis and Characterization of 1,3,5-Triarylpyrazol-4-Ols and 3,5-Diarylisoxazol-4-Ols from Chalcones and Theoretical Studies of the Stability of Pyrazol-4-Ol toward Acid Dehydration},
 urldate = {2026-03-27},
 volume = {1204},
