@article{collinCOtabExpedientSafe2019,
 abstract = {Bench-stable tablets (COtabs) have been developed for the rapid and safe production of carbon monoxide. The tablets can be made in less than 5 min without the use of a glovebox and only require a stock solution of an amine base to liberate a specific quantity of CO in a two-chamber system. The COtabs were tested in five different carbonylation reactions and provided similar yields compared to literature procedures. Finally, a gram-scale reaction was conducted, as well as 13C-isotope labeling of the anticancer drug, olaparib.},
 author = {Collin, Hugo P. and Reis, Wallace J. and Nielsen, Dennis U. and Lindhardt, Anders T. and Valle, Marcelo S. and Freitas, Rossimiriam P. and Skrydstrup, Troels},
 doi = {10.1021/acs.orglett.9b01423},
 file = {/home/lraposo/Zotero/storage/ARZIAV8Y/Collin et al. - 2019 - COtab Expedient and Safe Setup for Pd-Catalyzed Carbonylation Chemistry.pdf},
 issn = {1523-7060},
 journal = {Organic Letters},
 month = {August},
 number = {15},
 pages = {5775--5778},
 publisher = {American Chemical Society},
 shorttitle = {COtab},
 title = {COtab: Expedient and Safe Setup for Pd-Catalyzed Carbonylation Chemistry},
 urldate = {2026-03-27},
 volume = {21},
 year = {2019}
}
