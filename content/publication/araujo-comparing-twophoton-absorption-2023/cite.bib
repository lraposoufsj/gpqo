@article{araujoComparingTwophotonAbsorption2023,
 abstract = {We compared the experimental nonlinear optical responses (NLO) of one chalcone (BCH-1), two dibenzylideneacetone (BCH-2 and BCH-3), and two thiosemicarbazones dibenzylideneacetone (TSCD-1 and -2). The compounds were synthesized by the Claisen-Schmidt reaction and characterized using NMR, FTIR, and UV--Vis. The Z-scan technique, using femtosecond pulses, obtained two-photon absorption cross-section ($σ$2PA) spectra of the investigated compounds, which presented moderate values of $σ$2PA, ranging from 28~GM to 69~GM. Such $σ$2PA difference in the NLO response is usually associated with the length of the conjugated chain and the different functional groups used. For example, increasing the conjugated $π$-chain and peripherals groups from BCH-1 to BCH-2 led to a doubling effect on the magnitude of the NLO ($σ$BCH-12PA=28GM, $σ$BCH-22PA=64GM). A noticeable drop in the NLO response is observed from $σ$BCH-22PA=64GM to $σ$BCH-32PA=39GM due to the replacement of the 3,4,5 tri-methoxyphenyl by the thiophene aromatic peripheral group, respectively. The higher NLO response is attributed to compounds TSCD-1 and -2, with values of about 69~GM and 66~GM, respectively, indicating that bromo- and chloro-substituents do not influence the NLO response. According to the obtained results and considering the investigated compounds' short $π$-chain, we could claim that these classes of organic molecules are promising NLO materials.},
 author = {Araújo, Raiane S. and Sciuti, Lucas F. and Cocca, Leandro H. Z. and Lopes, Thaís O. and Silva, Aline A. and Abegão, Luis M. G. and Valle, Marcelo S. and Rodrigues Jr, José J. and Mendonça, Cleber R. and De Boni, Leonardo and Alencar, Márcio A. R. C.},
 doi = {10.1016/j.optmat.2023.113510},
 file = {/home/lraposo/Zotero/storage/9JGSQ9S9/Araújo et al. - 2023 - Comparing two-photon absorption of chalcone, dibenzylideneacetone and thiosemicarbazone derivatives.pdf;/home/lraposo/Zotero/storage/CITAQMMM/S0925346723000812.html},
 issn = {0925-3467},
 journal = {Optical Materials},
 keywords = {Nonlinear optical,Organic molecules,Two-photon absorption},
 month = {March},
 pages = {113510},
 title = {Comparing Two-Photon Absorption of Chalcone, Dibenzylideneacetone and Thiosemicarbazone Derivatives},
 urldate = {2026-03-27},
 volume = {137},
 year = {2023}
}
