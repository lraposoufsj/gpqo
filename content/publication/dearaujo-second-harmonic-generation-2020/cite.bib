@article{dearaujoSecondHarmonicGeneration2020,
 abstract = {In this work, we investigate theoretically and experimentally second harmonic generation (SHG) in three pyrazoline compounds, being two derivatives of dibenzylideneacetone (DBA) (C23H20N2 and C25H24N2O2) and one derivative of chalcone (C21H18N2). The compounds were synthesized after two steps employing a Claisen-Schmidt condensation followed by an addition-elimination reaction with phenylhydrazine. All compounds were characterized using NMR, FT-IR, UV-Vis, and XRD. We calculated the first-order hyperpolarizabilities of these molecules using program packages based on the time-dependent Hartree-Fock (TDHF) and density functional theory (DFT). SHG was characterized by Kurtz and Perry's powder method. We observed that these organic crystals present SHG efficiencies up to 5 times larger than the KDP, and we associated these values to their molecular structure and crystalline arrangements. The values obtained experimentally and theoretically evidence that these compounds have good potential for application in electronic devices based on second-order nonlinear responses.},
 author = {de Araújo, Raiane Sodré and de Alcântara, Aline Moreira and Abegão, Luis M. G. and de Souza, Yago Pereira and Brandão Silva, Antônio Carlos and Machado, Rogério and Joatan Rodrigues, José and Rodriguez Pliego, Josefredo and d'Errico, Francesco and Siqueira Valle, Marcelo and de Alencar, Márcio André Rodrigues Cavalcanti},
 doi = {10.1016/j.jphotochem.2019.112147},
 file = {/home/lraposo/Zotero/storage/6ZYL3A3R/de Araújo et al. - 2020 - Second harmonic generation in pyrazoline derivatives of dibenzylideneacetones and chalcone A combin.pdf;/home/lraposo/Zotero/storage/YR36RGYZ/S101060301931072X.html},
 issn = {1010-6030},
 journal = {Journal of Photochemistry and Photobiology A: Chemistry},
 keywords = {Density functional theory,First hyperpolarizability,Hartree-Fock,Pyrazoline,Second harmonic generation},
 month = {February},
 pages = {112147},
 shorttitle = {Second Harmonic Generation in Pyrazoline Derivatives of Dibenzylideneacetones and Chalcone},
 title = {Second Harmonic Generation in Pyrazoline Derivatives of Dibenzylideneacetones and Chalcone: A Combined Experimental and Theoretical Approach},
 urldate = {2026-03-27},
 volume = {388},
 year = {2020}
}
